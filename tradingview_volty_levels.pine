//@version=6
indicator("Volty Expan Close Levels", overlay=true)

length = input.int(5, "Length", minval=1)
numATRs = input.float(0.75, "ATR Mult", minval=0.0, step=0.05)
minATRPoints = input.float(0, "Min ATR Points (0 = off)", minval=0.0)
pointSize = input.float(0.01, "Point Size", minval=0.00001)
showCurrent = input.bool(true, "Show Current Bar Levels")

tr = ta.tr
rawATR = ta.sma(tr, length)
atrPass = minATRPoints <= 0 or rawATR >= minATRPoints * pointSize
atrs = rawATR * numATRs

// These are the exact stop prices used by:
// strategy.entry("VltClsLE", strategy.long, stop=close + atrs)
// strategy.entry("VltClsSE", strategy.short, stop=close - atrs)
upper = atrPass ? close + atrs : na
lower = atrPass ? close - atrs : na

plot(showCurrent ? upper : upper[1], "Buy Stop Level", color=color.lime, linewidth=2, style=plot.style_stepline)
plot(showCurrent ? lower : lower[1], "Sell Stop Level", color=color.red, linewidth=2, style=plot.style_stepline)
plot(close, "Close", color=color.gray, linewidth=1)

fill(
    plot(showCurrent ? upper : upper[1], "Upper Fill", color=color.new(color.lime, 100)),
    plot(showCurrent ? lower : lower[1], "Lower Fill", color=color.new(color.red, 100)),
    color=color.new(color.blue, 92),
    title="Volty Band"
)

plotchar(atrs, "ATRs", "", location=location.top, display=display.data_window)
plotchar(rawATR / pointSize, "Raw ATR Points", "", location=location.top, display=display.data_window)
plotchar(atrPass ? 1 : 0, "ATR Pass", "", location=location.top, display=display.data_window)
